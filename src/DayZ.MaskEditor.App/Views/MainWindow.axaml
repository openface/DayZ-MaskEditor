<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:DayZ.MaskEditor.App.Controls"
        x:Class="DayZ.MaskEditor.App.Views.MainWindow"
        x:Name="Root"
        x:CompileBindings="False"
        Width="1280" Height="820"
        MinWidth="900" MinHeight="600"
        Title="DayZ Mask Editor">

  <Window.KeyBindings>
    <KeyBinding Gesture="Escape" Command="{Binding DisarmCommand}"/>
  </Window.KeyBindings>

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Setup bar -->
    <Border Grid.Row="0" Padding="8" Background="#22000000">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,*,Auto,Auto,*,Auto,Auto,Auto"
            RowDefinitions="Auto" ColumnSpacing="6">
        <TextBlock Grid.Column="0" Text="layers.cfg:" VerticalAlignment="Center"/>
        <TextBox   Grid.Column="1" Text="{Binding CfgPath}" Watermark="path to layers.cfg"/>
        <Button    Grid.Column="2" Content="…" Command="{Binding BrowseCfgCommand}"/>

        <TextBlock Grid.Column="3" Text="satmap:" VerticalAlignment="Center" Margin="8,0,0,0"/>
        <TextBox   Grid.Column="4" Text="{Binding SatmapPath}" Watermark="satellite image"/>
        <Button    Grid.Column="5" Content="…" Command="{Binding BrowseSatmapCommand}"/>

        <TextBlock Grid.Column="6" Text="mask:" VerticalAlignment="Center" Margin="8,0,0,0"/>
        <TextBox   Grid.Column="7" Text="{Binding MaskPath}" Watermark="surface mask"/>
        <Button    Grid.Column="8" Content="…" Command="{Binding BrowseMaskCommand}"/>

        <Button    Grid.Column="9"  Content="Load"  Margin="8,0,0,0"
                   Command="{Binding LoadCommand}" IsEnabled="{Binding !IsBusy}"/>
        <Button    Grid.Column="10" Content="Save mask"
                   Command="{Binding SaveMaskCommand}" IsEnabled="{Binding !IsBusy}"/>
      </Grid>
    </Border>

    <!-- Main body -->
    <Grid Grid.Row="1" ColumnDefinitions="280,*,320">

      <!-- Left: surfaces + shapes tabs -->
      <Border Grid.Column="0" Padding="4" Background="#18000000">
        <TabControl>
          <TabControl.Styles>
            <Style Selector="TabItem">
              <Setter Property="FontSize" Value="14"/>
              <Setter Property="Padding" Value="8,4"/>
              <Setter Property="MinHeight" Value="0"/>
            </Style>
            <Style Selector="NumericUpDown">
              <Setter Property="ShowButtonSpinner" Value="False"/>
            </Style>
          </TabControl.Styles>

          <!-- Surfaces -->
          <TabItem Header="Surfaces">
            <DockPanel Margin="4">
              <Border DockPanel.Dock="Top" Padding="6" Margin="0,0,0,6"
                      Background="#22000000" CornerRadius="4">
                <!-- Fixed two-line layout so arming/unarming never shifts the list. -->
                <DockPanel>
                  <ToggleButton DockPanel.Dock="Right" VerticalAlignment="Center"
                                Margin="6,0,0,0" Padding="6"
                                IsChecked="{Binding IsEyedropperActive}"
                                ToolTip.Tip="Eyedropper — click a spot on the mask to arm the surface painted there">
                    <PathIcon Width="16" Height="16"
                              Data="M20.71 5.63l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-3.12 3.12-1.93-1.91-1.41 1.41 1.42 1.42L3 16.25V21h4.75l8.92-8.92 1.42 1.42 1.41-1.41-1.92-1.92 3.12-3.12c.4-.4.4-1.03.01-1.42zM6.92 19L5 17.08l8.06-8.06 1.92 1.92L6.92 19z"/>
                  </ToggleButton>
                  <StackPanel>
                    <TextBlock Text="{Binding ArmedText}"
                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="Click to arm · click again or Esc to stop"
                               FontSize="10" Opacity="0.55" Margin="0,2,0,0"
                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                </DockPanel>
              </Border>
              <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Surfaces}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button HorizontalAlignment="Stretch" Margin="0,1" Padding="4"
                              Command="{Binding #Root.DataContext.ArmSurfaceCommand}"
                              CommandParameter="{Binding}">
                        <ToolTip.Tip>
                          <StackPanel MaxWidth="220">
                            <Image Source="{Binding Thumbnail}" Width="96" Height="96"
                                   IsVisible="{Binding HasThumbnail}" Stretch="Uniform"
                                   Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding Tooltip}" TextWrapping="Wrap"/>
                          </StackPanel>
                        </ToolTip.Tip>
                        <Grid ColumnDefinitions="22,*,Auto">
                          <Border Grid.Column="0" Width="18" Height="18" CornerRadius="2"
                                  Background="{Binding Swatch}"
                                  BorderBrush="#80FFFFFF" BorderThickness="1"/>
                          <StackPanel Grid.Column="1" Margin="6,0,0,0">
                            <TextBlock Text="{Binding Name}"/>
                            <TextBlock Text="{Binding RgbText}" FontSize="10" Opacity="0.6"/>
                          </StackPanel>
                          <TextBlock Grid.Column="2" Text="{Binding CoverageText}"
                                     VerticalAlignment="Center" FontSize="11" Opacity="0.8"/>
                          <!-- Armed indicator: amber outline over the whole row. -->
                          <Border Grid.Column="0" Grid.ColumnSpan="3" Margin="-4"
                                  BorderBrush="#FFE0A000" BorderThickness="2" CornerRadius="3"
                                  IsHitTestVisible="False" IsVisible="{Binding IsArmed}"/>
                        </Grid>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </DockPanel>
          </TabItem>

          <!-- Terrain (Mapframe setup) -->
          <TabItem Header="Terrain">
            <ScrollViewer>
              <StackPanel Margin="4" Spacing="6">
                <TextBlock Text="Mapframe setup" FontWeight="Bold"/>
                <TextBlock Text="Copy these from Terrain Builder ▸ Mapframe properties."
                           FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6" RowSpacing="4"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Easting (m)" VerticalAlignment="Center"/>
                  <NumericUpDown Grid.Row="0" Grid.Column="1" Minimum="-1000000" Maximum="1000000"
                                 Increment="1000" Value="{Binding ShapeOffsetX, TargetNullValue=0}"/>
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Northing (m)" VerticalAlignment="Center"/>
                  <NumericUpDown Grid.Row="1" Grid.Column="1" Minimum="-1000000" Maximum="1000000"
                                 Increment="1000" Value="{Binding ShapeOffsetY, TargetNullValue=0}"/>
                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Grid size (cells)" VerticalAlignment="Center"/>
                  <NumericUpDown Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="32768"
                                 Increment="1" Value="{Binding GridCells, TargetNullValue=0}"/>
                  <TextBlock Grid.Row="3" Grid.Column="0" Text="Cell size (m)" VerticalAlignment="Center"/>
                  <NumericUpDown Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="100000"
                                 Increment="1" Value="{Binding CellSize, TargetNullValue=0}"/>
                  <TextBlock Grid.Row="4" Grid.Column="0" Text="Source image (px)" VerticalAlignment="Center"/>
                  <NumericUpDown Grid.Row="4" Grid.Column="1" Minimum="0" Maximum="131072"
                                 Increment="256" Value="{Binding SatSourcePx, TargetNullValue=0}"/>
                  <TextBlock Grid.Row="5" Grid.Column="0" Text="Terrain size" VerticalAlignment="Center"/>
                  <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding TerrainMetersText}"
                             VerticalAlignment="Center" Opacity="0.8"/>
                  <TextBlock Grid.Row="6" Grid.Column="0" Text="Resolution" VerticalAlignment="Center"/>
                  <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ResolutionText}"
                             VerticalAlignment="Center" Opacity="0.8"/>
                  <TextBlock Grid.Row="7" Grid.Column="0" Text="Tile size (px)" VerticalAlignment="Center"/>
                  <NumericUpDown Grid.Row="7" Grid.Column="1" Minimum="0" Maximum="8192"
                                 Increment="1" Value="{Binding TileSize, TargetNullValue=0}"/>
                  <TextBlock Grid.Row="8" Grid.Column="0" Text="Actual overlap (px)" VerticalAlignment="Center"/>
                  <NumericUpDown Grid.Row="8" Grid.Column="1" Minimum="0" Maximum="4096"
                                 Increment="1" Value="{Binding TileOverlap, TargetNullValue=0}"/>
                  <TextBlock Grid.Row="9" Grid.Column="0" Text="Tiles in row" VerticalAlignment="Center"/>
                  <NumericUpDown Grid.Row="9" Grid.Column="1" Minimum="0" Maximum="1024"
                                 Increment="1" Value="{Binding TilesInRow, TargetNullValue=0}"/>
                  <TextBlock Grid.Row="10" Grid.Column="0" Text="Max colours" VerticalAlignment="Center"/>
                  <NumericUpDown Grid.Row="10" Grid.Column="1" Minimum="0" Maximum="64"
                                 Increment="1" Value="{Binding TileMaxColors, TargetNullValue=0}"/>
                </Grid>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <!-- Shapes (overlay layers) -->
          <TabItem Header="Shapes">
            <DockPanel Margin="4">
              <StackPanel DockPanel.Dock="Top" Spacing="6">
                <Border Padding="6" Background="#22000000" CornerRadius="4">
                  <TextBlock Text="{Binding ShapeStatus}" TextWrapping="Wrap" FontSize="11"/>
                </Border>
                <Button HorizontalAlignment="Stretch" Content="Add shapefile(s)…"
                        Command="{Binding AddShapefilesCommand}"/>
              </StackPanel>

              <ScrollViewer>
                <ItemsControl ItemsSource="{Binding ShapeLayers}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,2" Padding="6" Background="#22000000" CornerRadius="4">
                        <StackPanel Spacing="4">
                          <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                            <Button Grid.Column="0" Width="20" Height="20" Padding="0"
                                    Background="{Binding Swatch}"
                                    Command="{Binding CycleColorCommand}"
                                    ToolTip.Tip="Click to change colour"/>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                              <TextBlock Text="{Binding Name}"/>
                              <TextBlock Text="{Binding FeatureCount, StringFormat='{}{0} features'}"
                                         FontSize="10" Opacity="0.6"/>
                            </StackPanel>
                            <CheckBox Grid.Column="2" IsChecked="{Binding IsVisible}"
                                      VerticalAlignment="Center" ToolTip.Tip="Visible"/>
                            <Button Grid.Column="3" Content="✕" Padding="6,2"
                                    Command="{Binding RemoveCommand}" ToolTip.Tip="Remove layer"/>
                          </Grid>
                          <Slider Minimum="0.1" Maximum="1" Value="{Binding Opacity}"/>
                          <TextBlock Text="{Binding ExtentProblem, StringFormat='⚠ {0}'}"
                                     IsVisible="{Binding HasProblem}"
                                     Foreground="#FF6060" FontSize="10" TextWrapping="Wrap"/>
                          <CheckBox Content="Colour by TB layer" FontSize="11"
                                    IsVisible="{Binding CanGroup}"
                                    IsChecked="{Binding GroupByLayer}"
                                    ToolTip.Tip="Groups by the shape's Terrain Builder layer (the __LAYER field) — these are TB layers, not DayZ surfaces."/>
                          <TextBlock Text="Terrain Builder layers — not DayZ surfaces"
                                     IsVisible="{Binding GroupByLayer}"
                                     FontSize="9" Opacity="0.55" FontStyle="Italic"
                                     Margin="8,0,0,0" TextWrapping="Wrap"/>
                          <ItemsControl ItemsSource="{Binding Groups}" Margin="8,0,0,0"
                                        IsVisible="{Binding GroupByLayer}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,1" ColumnSpacing="4">
                                  <Button Grid.Column="0" Width="13" Height="13" Padding="0"
                                          Background="{Binding Swatch}"
                                          Command="{Binding CycleColorCommand}"
                                          ToolTip.Tip="Change colour"/>
                                  <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="10"
                                             VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                  <TextBlock Grid.Column="2" Text="{Binding Count}" FontSize="9"
                                             Opacity="0.5" VerticalAlignment="Center"/>
                                  <CheckBox Grid.Column="3" IsChecked="{Binding IsVisible}"
                                            ToolTip.Tip="Visible"/>
                                </Grid>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </DockPanel>
          </TabItem>

        </TabControl>
      </Border>

      <!-- Center: editing canvas -->
      <Border Grid.Column="1" Background="#202020">
        <ctrl:MaskCanvas x:Name="Canvas"/>
      </Border>

      <!-- Right: tools + log -->
      <Border Grid.Column="2" Padding="8" Background="#18000000">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Spacing="6">
            <TextBlock Text="Brush" FontWeight="Bold"/>
            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="6" RowSpacing="4">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Size" VerticalAlignment="Center"/>
              <Slider Grid.Row="0" Grid.Column="1" Minimum="1" Maximum="512"
                      IsSnapToTickEnabled="True" TickFrequency="1"
                      Value="{Binding BrushSize}"/>
              <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"
                         MinWidth="40" TextAlignment="Right"
                         Text="{Binding BrushSize, StringFormat='{}{0} px'}"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Overlay" VerticalAlignment="Center"/>
              <Slider Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Minimum="0" Maximum="1"
                      Value="{Binding OverlayOpacity}"/>
            </Grid>

            <Separator/>
            <TextBlock Text="Validate &amp; fix" FontWeight="Bold"/>
            <Button HorizontalAlignment="Stretch" Content="Check legend colours"
                    Command="{Binding CheckLegendCommand}" IsEnabled="{Binding !IsBusy}"/>
            <Button HorizontalAlignment="Stretch" Content="Fix: snap strays → legend"
                    Command="{Binding SnapToLegendCommand}" IsEnabled="{Binding CanSnapFix}"
                    ToolTip.Tip="Enabled after Check legend colours finds strays. Replaces every non-legend pixel with the nearest legend colour."/>
            <TextBlock Text="Tile parameters are on the Terrain tab." FontSize="10" Opacity="0.6"/>
            <Button HorizontalAlignment="Stretch" Content="Check colours per tile"
                    Command="{Binding CheckTilesCommand}" IsEnabled="{Binding !IsBusy}"/>
            <Button HorizontalAlignment="Stretch" Content="Fix: consolidate over-limit tiles"
                    Command="{Binding ConsolidateTilesCommand}" IsEnabled="{Binding CanTileFix}"
                    ToolTip.Tip="Enabled after Check colours per tile finds over-limit tiles. Reduces each over-budget tile to the colour limit by replacing its rarest colours."/>
            <CheckBox Content="Show tile grid" IsChecked="{Binding ShowTileGrid}"/>
            <Button HorizontalAlignment="Stretch" Content="Check image specs"
                    Command="{Binding CheckSpecsCommand}" IsEnabled="{Binding !IsBusy}"/>

            <Separator/>
            <TextBlock Text="Log" FontWeight="Bold"/>
          </StackPanel>

          <TextBox Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True"
                   FontFamily="Consolas,Menlo,monospace" FontSize="11"
                   AcceptsReturn="True" TextWrapping="NoWrap"
                   VerticalContentAlignment="Top"/>
        </DockPanel>
      </Border>
    </Grid>

    <!-- Status bar -->
    <Border Grid.Row="2" Padding="8,4" Background="#22000000">
      <TextBlock Text="{Binding Status}" Opacity="0.8" FontSize="12"/>
    </Border>
  </Grid>
</Window>
